<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_light"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">
        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Today"
            android:textColor="@color/widget_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_header_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tasks"
            android:textColor="@color/widget_primary"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_0_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/row_0_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check_empty"
            android:layout_marginEnd="8dp" />
        <TextView
            android:id="@+id/row_0_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/widget_text_primary"
            android:maxLines="1"
            android:ellipsize="end" />
        <ImageButton
            android:id="@+id/row_0_complete"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_check_empty"
            android:background="@null"
            android:contentDescription="Complete" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_1_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/row_1_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check_empty"
            android:layout_marginEnd="8dp" />
        <TextView
            android:id="@+id/row_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/widget_text_primary"
            android:maxLines="1"
            android:ellipsize="end" />
        <ImageButton
            android:id="@+id/row_1_complete"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_check_empty"
            android:background="@null"
            android:contentDescription="Complete" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_2_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/row_2_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check_empty"
            android:layout_marginEnd="8dp" />
        <TextView
            android:id="@+id/row_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/widget_text_primary"
            android:maxLines="1"
            android:ellipsize="end" />
        <ImageButton
            android:id="@+id/row_2_complete"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_check_empty"
            android:background="@null"
            android:contentDescription="Complete" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_overflow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/widget_text_secondary"
        android:gravity="center"
        android:visibility="gone" />
</LinearLayout>
